# Convex
NEXT_PUBLIC_CONVEX_URL=

# ElevenLabs
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# The following secrets are stored as Convex environment variables (never client-side):
# ELEVENLABS_API_KEY — used by fetchConversation and getAudio actions
#
# AI provider rollout:
# AI_PROVIDER=openrouter|foundry
# OPENROUTER_API_KEY — retained only during the rollback window
# FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com
# FOUNDRY_API_KEY — account key shared by the Foundry deployments
# FOUNDRY_SYNTHESIS_BACKEND=claude|gpt5mini
# FOUNDRY_CLAUDE_DEPLOYMENT=fabric-claude-haiku-4-5
# FOUNDRY_OPENAI_FALLBACK_DEPLOYMENT=fabric-gpt5-mini-fallback
# FOUNDRY_SAFETY_DEPLOYMENT=fabric-description-safety
